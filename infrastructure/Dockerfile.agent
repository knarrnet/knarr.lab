# knarr.lab agent node image
#
# Build:
#   docker build -f infrastructure/Dockerfile.agent -t knarr-lab:latest .
#
# Requires knarr source at .knarr-src/ (git clone or submodule)

FROM python:3.14-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install knarr from source
COPY .knarr-src/ /tmp/knarr-src/
RUN pip install --no-cache-dir /tmp/knarr-src/ && rm -rf /tmp/knarr-src/

# Create directories
RUN mkdir -p /app/skills /app/data /app/plugins

EXPOSE 9000 8080 8081

CMD ["knarr", "serve"]
